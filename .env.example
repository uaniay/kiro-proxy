# Required: Proxy API key (min 16 characters)
PROXY_API_KEY=your-secure-api-key-here

# Multi-user mode: uncomment to enable (SQLite)
# DATABASE_URL=sqlite:data/kiro-proxy.db?mode=rwc

# Kiro credentials (from AWS SSO device code flow)
KIRO_REFRESH_TOKEN=
KIRO_CLIENT_ID=
KIRO_CLIENT_SECRET=

# AWS region for Kiro API (default: us-east-1)
KIRO_REGION=us-east-1

# AWS SSO region (if different from KIRO_REGION)
# KIRO_SSO_REGION=

# Server settings
# SERVER_HOST=0.0.0.0
# SERVER_PORT=9199

# Logging: trace, debug, info, warn, error
# LOG_LEVEL=info
